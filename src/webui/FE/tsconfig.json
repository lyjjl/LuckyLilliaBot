{
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@common/types": ["../../common/types"],
      "@ntqqapi/types": ["../../ntqqapi/types"],
      "@/*": ["./*"]
    },
    "types": ["vite/client"],
    "jsx": "react",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "module": "esnext"
  },
  "include": ["./**/*", "../../**/*"],
  "exclude": ["node_modules"]
}
